# Site Configuration
NEXT_PUBLIC_SITE_URL=https://casadelvino.com
NEXT_PUBLIC_API_URL=https://api.casadelvino.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/casa_del_vino_db

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://casadelvino.com

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Service
SMTP_FROM=noreply@casadelvino.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password

# File Storage (Optional - for images/uploads)
NEXT_PUBLIC_STORAGE_BUCKET=casa-del-vino
STORAGE_API_KEY=your-api-key

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=GA-xxxxxxxxx-x
